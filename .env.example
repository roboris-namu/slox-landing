# ============================================================================
# slox-landing 환경변수 템플릿
# ----------------------------------------------------------------------------
# 이 파일은 git에 커밋됩니다. 실제 키는 .env.local에 넣으세요.
# 새 환경에서 셋업할 때 이 파일을 .env.local로 복사 후 값을 채우세요:
#   cp .env.example .env.local
# ============================================================================

# OpenAI - 정비도사 LLM/임베딩
OPENAI_API_KEY=sk-proj-...

# Supabase - 정비도사 ingest API용 (서버 사이드 전용)
SUPABASE_SERVICE_ROLE_KEY=

# 정비도사 ingest API 보호용 토큰 (관리자 전용, 임의의 긴 문자열)
ADMIN_TOKEN=
